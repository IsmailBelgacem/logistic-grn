Cell["\<\
Reduce each Boolean rule to its minimal disjunctive normal form (the built-in \
BooleanMinimize) BEFORE translating it to ODEs. This canonicalisation is \
intentional and is not part of the De Morgan map: BooleanToOdeSystem below is \
a pure translator. For this network the rules are already in minimal DNF, so \
FBmin coincides with FB.\
\>", "Text",
 CellChangeTimes->{{3.9919140992852907`*^9, 
  3.991914102754054*^9}},ExpressionUUID->"b7e1c0de-0000-4000-8000-\
000000000001"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FBmin", "=", 
  RowBox[{"FB", "/.", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"lhs_", "\[Rule]", "rhs_"}], ")"}], "\[RuleDelayed]", 
    RowBox[{"(", 
     RowBox[{"lhs", "\[Rule]", 
      RowBox[{"BooleanMinimize", "[", 
       RowBox[{"rhs", ",", "\"\<DNF\>\""}], "]"}]}], ")"}]}]}]}]], "Input",
 CellLabel->"In[29]:=",ExpressionUUID->"b7e1c0de-0000-4000-8000-000000000002"],

