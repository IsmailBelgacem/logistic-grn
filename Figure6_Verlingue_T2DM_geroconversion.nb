Cell[CellGroupData[{

Cell["Stable states (sanity check)", "Subsubsection",ExpressionUUID->"433228ef-05d4-4d9b-a737-c11437f99337"],

Cell["\<\
Un point fixe booleen (x = F(x)) correspond a un phenotype cellulaire stable \
au sens du papier : un attracteur vers lequel convergent les trajectoires \
MaBoSS. Verification INDEPENDANTE de l'integration ODE : elle porte sur FB \
(forme booleenne exacte, pre-minimisation, puisque x=F(x) ne depend pas de la \
syntaxe). Le reseau T2DM a exactement 2 points fixes (Insulin=GF=1 fixes), \
qui concordent noeud par noeud sur les 25 genes :
  - Etat proliferatif : E2F1=G1_S=CDK2=AKT=1, Senescence=p21=p16=0
  - Etat senescent : Senescence=p21=p53=PTEN=pRB=1, G1_S=E2F1=CDK2=0\
\>", "Text",
 CellChangeTimes->{
  3.991916083057962*^9},ExpressionUUID->"90b91e74-efa2-4044-89dc-\
ad04257be85c"],

Cell[CellGroupData[{

Cell["\<\
stateProliferative = <|Insulin -> True, GF -> True, Senescence -> False,
   G1\[LetterSpace]S -> True, MAPK -> True, p16 -> False, MDM2 -> False,
   p53 -> True, p21 -> False, AKT -> True, mTORC1\[LetterSpace]S6K1 -> True,
   ATP -> True, IRS\[LetterSpace]PIK3CA -> False, AMPK -> False, PTEN -> False,
   TSC -> False, MYC -> False, CDK2 -> True, pRB -> False, E2F1 -> True,
   PRC -> False, Metabolism -> True, PP2A -> False, FOXO -> False, PP1C -> \
True|>;

stateSenescent = <|Insulin -> True, GF -> True, Senescence -> True,
   G1\[LetterSpace]S -> False, MAPK -> True, p16 -> False, MDM2 -> False,
   p53 -> True, p21 -> True, AKT -> False, mTORC1\[LetterSpace]S6K1 -> True,
   ATP -> True, IRS\[LetterSpace]PIK3CA -> False, AMPK -> False, PTEN -> \
True,
   TSC -> False, MYC -> False, CDK2 -> False, pRB -> True, E2F1 -> False,
   PRC -> False, Metabolism -> True, PP2A -> False, FOXO -> False, PP1C -> \
True|>;

checkFixedPoint[state_] := AllTrue[FB, (#[[1]] /. state) === (#[[2]] /. \
state) &]

{checkFixedPoint[stateProliferative], checkFixedPoint[stateSenescent]}\
\>", "Input",
 CellChangeTimes->{3.99191285938276*^9},
 CellLabel->"In[78]:=",ExpressionUUID->"86569268-ac3a-4c91-9c8b-e5052bf32db1"],

