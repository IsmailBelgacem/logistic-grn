Cell["\<\
(* arrondi propre a 0.01 des associations figees *)
\[Kappa] = Round[#, 0.01] & /@ \[Kappa];
\[Gamma] = Round[#, 0.01] & /@ \[Gamma];
\[Theta] = Round[#, 0.01] & /@ \[Theta];
initialcondition = Round[#, 0.01] & /@ initialcondition;\
\>", "Input",
 CellLabel->"In[68]:=",ExpressionUUID->"7cfe190e-9bb6-4c51-a4dd-f21b4bee8283"],

Cell[CellGroupData[{

Cell["ODE", "Subsubsection",ExpressionUUID->"d09059c4-cdc1-4479-b36f-6f7eacd54615"],

Cell["\<\
Chaque gene i obeit a dx_i/dt = \[Kappa]_i*\[CapitalPhi]_i(x) - \
\[Gamma]_i*x_i, ou \[CapitalPhi]_i est le produit de noyaux logistiques \
obtenu en appliquant la formule de De Morgan a la regle DNF minimale de FBmin \
(BooleanToOdeSystem, package BooleanToLogisticODE`). fstep = {logisticm, \
logisticp} fournit les noyaux decroissant (repression) et croissant \
(activation). NDSolve integre de t=0 a t=60 depuis initialcondition, et le \
trace couvre le meme intervalle [0,60].\
\>", "Text",ExpressionUUID->"f7fd30ed-e6f7-4c52-8627-a18338a9fbee"],

Cell["\<\
system1 = BooleanToOdeSystem[FBmin, t, \[Kappa], \[Gamma], \[Theta], n,
   initialcondition, {logisticm, logisticp}];\
\>", "Input",
 CellLabel->"In[73]:=",ExpressionUUID->"a47e93c8-5b60-4d96-82ed-3c034ffa8f6d"],

Cell[CellGroupData[{

Cell["Framed @ TableForm[system1]", "Input",
 CellLabel->"In[74]:=",ExpressionUUID->"cadc3924-510e-4675-88f2-ff2c4ae79a89"],

