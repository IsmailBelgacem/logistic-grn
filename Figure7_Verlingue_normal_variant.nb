Notebook[{

Cell[CellGroupData[{
Cell["\<\
ODE simulation RESEAU BOOLEEN VERLINGUE 2016 -- NORMAL VARIANT\
\>", "Title",ExpressionUUID->"28fc654b-4074-414e-a073-32859e4d4316"],

Cell["SetDirectory @ NotebookDirectory[];", "Input",
 CellLabel->"In[66]:=",ExpressionUUID->"fd5dd13c-6ecd-4d06-91c0-45d827fa28e7"],

Cell["<< BooleanToLogisticODE`", "Input",
 CellLabel->"In[67]:=",ExpressionUUID->"c3227a83-18a8-4e31-90dc-34fda6aa7144"],

Cell["Unprotect[t]; Clear[t]; Protect[t];", "Input",
 CellLabel->"In[68]:=",ExpressionUUID->"6e42468c-c228-4010-bcd8-de274b436700"],

Cell[CellGroupData[{

Cell["RESEAU BOOLEEN VERLINGUE 2016 -- NORMAL VARIANT", "Section",ExpressionUUID->"6d878b4e-e008-4fdd-a483-49983bc61509"],

Cell["", "Text",
 CellChangeTimes->{
  3.991920141366837*^9},ExpressionUUID->"9d75565f-06ac-488a-a19d-\
c30f59e47933"],

Cell["", "Text",
 CellChangeTimes->{{3.991920133671247*^9, 
  3.991920144937752*^9}},ExpressionUUID->"251279c4-21a0-4a24-8011-\
06b31dca909a"],

Cell["\<\
FBraw = {
 Insulin -> True,
 GF -> True,
 Therapy -> True,
 Senescence -> (mTORC1\[LetterSpace]S6K1 || p16) && (p16 || p21),
 G1\[LetterSpace]S -> CDK2 && E2F1 && Metabolism && !p21,
 MAPK -> GF && !PP2A,
 p16 -> !E2F1 && MAPK && !p53 && !PRC,
 MDM2 -> (AKT || p16 || p53) && !E2F1 && !mTORC1\[LetterSpace]S6K1 && !MYC,
 p53 -> !MDM2,
 p21 -> !AKT && (FOXO || p53) && !MYC,
 AKT -> (CDK2 || IRS\[LetterSpace]PIK3CA) && !PP2A && !PTEN,
 mTORC1\[LetterSpace]S6K1 -> !AMPK && !TSC,
 ATP -> Metabolism,
 IRS\[LetterSpace]PIK3CA -> Insulin,
 AMPK -> !ATP && p53,
 PTEN -> !AKT && p53,
 TSC -> !AKT && AMPK && !MAPK,
 MYC -> E2F1 && MAPK && mTORC1\[LetterSpace]S6K1 && !p53,
 CDK2 -> (E2F1 || MYC) && mTORC1\[LetterSpace]S6K1 && !p21,
 pRB -> !CDK2,
 E2F1 -> E2F1 && (GF || MYC) && !pRB,
 PRC -> !AKT && MYC,
 Metabolism -> (AKT || PP1C) && (MAPK || mTORC1\[LetterSpace]S6K1),
 PP2A -> !mTORC1\[LetterSpace]S6K1,
 FOXO -> !AKT && (AMPK || Metabolism || p16) && !MAPK,
 PP1C -> AKT || MAPK
};\
\>", "Input",
 CellLabel->"In[69]:=",ExpressionUUID->"2f621e91-01a7-40d1-a230-05ecd3670008"],

Cell["", "Text",
 CellChangeTimes->{
  3.991920149787765*^9},ExpressionUUID->"8c9bd96f-b60f-4228-a151-\
55cd96306e9f"],

Cell["FB = DeleteCases[FBraw, Therapy -> _];", "Input",
 CellLabel->"In[70]:=",ExpressionUUID->"e530836a-d484-4b97-8ae1-880e7c51f9db"],

Cell["", "Text",
 CellChangeTimes->{
  3.991920152978425*^9},ExpressionUUID->"94bc3a2b-7a04-45b0-910f-\
b48282bc6690"],

Cell["\<\
FBmin = FB /. (lhs_ -> rhs_) :> (lhs -> BooleanMinimize[rhs, \"DNF\"]);\
\>", "Input",
 CellLabel->"In[71]:=",ExpressionUUID->"c20c42dd-a4e8-4472-b573-e37a973e5714"],

Cell["", "Text",
 CellChangeTimes->{
  3.991920157516356*^9},ExpressionUUID->"78eee9e4-a466-4ca2-a905-\
5d54e545383e"],

Cell["\<\
\[Kappa] = <|
  Insulin -> 86.8963, GF -> 72.4351, Senescence -> 94.6186, G1\[LetterSpace]S \
-> 93.7670,
  MAPK -> 62.8255, p16 -> 84.1431, MDM2 -> 96.6196, p53 -> 54.0983, p21 -> \
64.8349,
  AKT -> 53.5813, mTORC1\[LetterSpace]S6K1 -> 74.3393, ATP -> 73.6526,
  IRS\[LetterSpace]PIK3CA -> 64.9635, AMPK -> 57.7498, PTEN -> 60.5431, TSC \
-> 60.4151,
  MYC -> 58.4264, CDK2 -> 72.6472, pRB -> 85.5416, E2F1 -> 54.0984, PRC -> \
81.4405,
  Metabolism -> 62.1464, PP2A -> 80.4183, FOXO -> 93.0308, PP1C -> 88.6539
|>;

\[Gamma] = <|
  Insulin -> 0.3092, GF -> 1.2442, Senescence -> 0.5957, G1\[LetterSpace]S -> \
0.8056,
  MAPK -> 1.3449, p16 -> 0.3772, MDM2 -> 1.5876, p53 -> 0.4196, p21 -> \
1.1774,
  AKT -> 0.3051, mTORC1\[LetterSpace]S6K1 -> 1.2706, ATP -> 1.7608,
  IRS\[LetterSpace]PIK3CA -> 0.8646, AMPK -> 1.4242, PTEN -> 0.8750, TSC -> \
0.9335,
  MYC -> 1.1724, CDK2 -> 0.6951, pRB -> 1.4941, E2F1 -> 0.8848, PRC -> \
1.5997,
  Metabolism -> 0.5707, PP2A -> 0.7755, FOXO -> 0.3583, PP1C -> 1.5265
|>;

\[Theta] = <|
  Insulin -> 15.6650, GF -> 15.8662, Senescence -> 17.3886, G1\[LetterSpace]S \
-> 18.2190,
  MAPK -> 16.8623, p16 -> 15.4681, MDM2 -> 12.5930, p53 -> 15.5627, p21 -> \
15.2005,
  AKT -> 10.5953, mTORC1\[LetterSpace]S6K1 -> 10.6927, ATP -> 15.8599,
  IRS\[LetterSpace]PIK3CA -> 12.8231, AMPK -> 15.7422, PTEN -> 19.4743, TSC \
-> 18.9398,
  MYC -> 13.5479, CDK2 -> 16.2350, pRB -> 13.7492, E2F1 -> 18.3530, PRC -> \
16.2775,
  Metabolism -> 18.2466, PP2A -> 19.7952, FOXO -> 13.8287, PP1C -> 11.1833
|>;

n = 4;

initialcondition = <|
  Insulin -> 63.5812, GF -> 14.7108, Senescence -> 61.7234, G1\[LetterSpace]S \
-> 96.8135,
  MAPK -> 95.4912, p16 -> 10.3455, MDM2 -> 9.5610, p53 -> 62.8235, p21 -> \
51.1062,
  AKT -> 35.3197, mTORC1\[LetterSpace]S6K1 -> 28.5190, ATP -> 46.3278,
  IRS\[LetterSpace]PIK3CA -> 94.5954, AMPK -> 15.4485, PTEN -> 95.8189, TSC \
-> 84.1208,
  MYC -> 69.4285, CDK2 -> 76.1456, pRB -> 17.0991, E2F1 -> 55.7069, PRC -> \
77.6568,
  Metabolism -> 20.7439, PP2A -> 56.7135, FOXO -> 0.8879, PP1C -> 41.6233
|>;\
\>", "Input",
 CellLabel->"In[72]:=",ExpressionUUID->"f9f980e3-bf7d-41ec-86e3-6117cb6ccd19"],

Cell[CellGroupData[{

Cell["ODE", "Subsubsection",ExpressionUUID->"22cdd525-f542-4e05-b4ae-a394a221e4f5"],

Cell["", "Text",
 CellChangeTimes->{{3.991920164897223*^9, 
  3.991920167056849*^9}},ExpressionUUID->"16a8be3b-9388-4554-b6a9-\
ed6b8cb08c69"],

Cell["\<\
system1 = BooleanToOdeSystem[FBmin, t, \[Kappa], \[Gamma], \[Theta], n,
   initialcondition, {logisticm, logisticp}];\
\>", "Input",
 CellChangeTimes->{{3.991920168998988*^9, 3.9919201695157413`*^9}},
 CellLabel->"In[81]:=",ExpressionUUID->"7e82ec4f-100a-495e-b442-73fb806f6436"],

Cell["fun = (#[t] &) /@ Keys[FB];", "Input",
 CellLabel->"In[82]:=",ExpressionUUID->"282a1bb8-3465-4812-a740-3d9d86d76a60"],

Cell["\<\
S = NDSolve[system1, Keys[FB], {t, 0, 60}, MaxSteps -> Infinity];\
\>", "Input",
 CellLabel->"In[83]:=",ExpressionUUID->"e5ce29e2-bca3-467d-a69f-f17f84349d5e"],

Cell[CellGroupData[{

Cell["\<\
Plot[Evaluate[fun /. S[[1]]], {t, 0, 60}, PlotRange -> All,
 PlotLegends -> Keys[FB], ImageSize -> Large,
 AxesLabel -> {\"t\", \"Expression level\"},
 PlotLabel -> \"Verlingue 2016 -- Normal variant -- logistic ODE (n = 4)\"]\
\>", "Input",
 CellLabel->"In[84]:=",ExpressionUUID->"bab5f074-cbda-419d-9ba9-f4802b653e4c"],

