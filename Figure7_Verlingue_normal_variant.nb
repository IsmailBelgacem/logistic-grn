  3.991920199770301*^9}},ExpressionUUID->"d70b19ee-f8b5-433f-a72c-\
f2f84d555b6b"],

Cell["", "Text",
 CellChangeTimes->{{3.9919201817298803`*^9, 
  3.99192018881841*^9}},ExpressionUUID->"3a7977a2-ecb1-49e6-82ef-\
45e69420dcab"],

Cell[CellGroupData[{

Cell["\<\
stateAktActiveNonCycling = <|Insulin -> True, GF -> True, Senescence -> \
False,
   G1\[LetterSpace]S -> False, MAPK -> True, p16 -> False, MDM2 -> False,
   p53 -> True, p21 -> False, AKT -> True, mTORC1\[LetterSpace]S6K1 -> True,
   ATP -> True, IRS\[LetterSpace]PIK3CA -> True, AMPK -> False, PTEN -> \
False,
   TSC -> False, MYC -> False, CDK2 -> False, pRB -> True, E2F1 -> False,
   PRC -> False, Metabolism -> True, PP2A -> False, FOXO -> False, PP1C -> \
True|>;

stateSenescent = <|Insulin -> True, GF -> True, Senescence -> True,
   G1\[LetterSpace]S -> False, MAPK -> True, p16 -> False, MDM2 -> False,
   p53 -> True, p21 -> True, AKT -> False, mTORC1\[LetterSpace]S6K1 -> True,
   ATP -> True, IRS\[LetterSpace]PIK3CA -> True, AMPK -> False, PTEN -> True,
   TSC -> False, MYC -> False, CDK2 -> False, pRB -> True, E2F1 -> False,
   PRC -> False, Metabolism -> True, PP2A -> False, FOXO -> False, PP1C -> \
True|>;

stateProliferative = <|Insulin -> True, GF -> True, Senescence -> False,
   G1\[LetterSpace]S -> True, MAPK -> True, p16 -> False, MDM2 -> False,
   p53 -> True, p21 -> False, AKT -> True, mTORC1\[LetterSpace]S6K1 -> True,
   ATP -> True, IRS\[LetterSpace]PIK3CA -> True, AMPK -> False, PTEN -> \
False,
   TSC -> False, MYC -> False, CDK2 -> True, pRB -> False, E2F1 -> True,
   PRC -> False, Metabolism -> True, PP2A -> False, FOXO -> False, PP1C -> \
True|>;

checkFixedPoint[state_] := AllTrue[FB, (#[[1]] /. state) === (#[[2]] /. \
state) &];

{checkFixedPoint[stateAktActiveNonCycling], checkFixedPoint[stateSenescent],
 checkFixedPoint[stateProliferative]}\
\>", "Input",
 CellChangeTimes->{{3.991920184386405*^9, 3.991920184998618*^9}},
 CellLabel->"In[85]:=",ExpressionUUID->"00f23e74-c593-4882-8b9d-2b338cfb5ac5"],

