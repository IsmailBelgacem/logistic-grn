       RowBox[{"[", "1", "]"}], "]"}], "[", "\"\<periods\>\"", "]"}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"inset", "   ", "=", " ", 
     RowBox[{"Histogram", "[", 
      RowBox[{
      "per4", ",", " ", "Automatic", ",", " ", "\"\<Count\>\"", ",", "\n", 
       "   ", 
