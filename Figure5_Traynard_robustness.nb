              RowBox[{"perBase", ",", " ", "0"}], "}"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{"perBase", ",", " ", 
               RowBox[{"10", "^", "6"}]}], "}"}]}], "}"}], "]"}]}], "}"}]}], ",",
        "\n", "   ", 
       RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
       RowBox[{"FrameLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<period\>\"", ",", " ", "None"}], "}"}]}], ",", "\n", 
       "   ", 
       RowBox[{"PlotLabel", " ", "->", " ", "\"\<period at n=4\>\""}], ",", 
       " ", 
       RowBox[{"ImageSize", " ", "->", " ", "200"}], ",", " ", 
       RowBox[{"LabelStyle", " ", "->", " ", "9"}]}], "]"}]}], ";"}], "\n", "\n", 
