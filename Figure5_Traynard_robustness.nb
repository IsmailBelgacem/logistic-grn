       RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
       RowBox[{"FrameLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<steepness n\>\"", ",", 
          " ", "\"\<sustained limit cycle (%)\>\""}], "}"}]}], ",", "\n", 
       "   ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<(b) fraction sustaining a limit cycle\>\""}], ",", " ", 
