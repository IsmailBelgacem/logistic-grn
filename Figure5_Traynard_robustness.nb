         RowBox[{
          RowBox[{"(", 
           RowBox[{"ymax", " ", "+", " ", "ymin"}], ")"}], "/", "2"}]}], ";", 
        "\n", "    ", 
        RowBox[{"cross", " ", "=", " ", 
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"Range", "[", 
            RowBox[{
             RowBox[{"Length", "[", "ys", "]"}], " ", "-", " ", "1"}], "]"}], 
           ",", " ", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"ys", "[", 
