Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"(", "b", ")"}], " ", "fraction", " ", "sustaining", " ", "a", " ",
      "limit", " ", "cycle", " ", "vs", " ", "n"}], ",", " ", 
    RowBox[{
    "with", " ", "a", " ", "period", " ", "histogram", " ", "inset"}]}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"fracs", "   ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"#", "[", "\"\<frac\>\"", "]"}], " ", "&"}], " ", "/@", " ", 
      "results"}]}], ";"}], "\n", 
