Cell[CellGroupData[{

Cell["Latin-hypercube sampler and integration", "Section",ExpressionUUID->"b03859e5-4b74-4063-af44-d0037778d871"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Latin", "-", 
    RowBox[{"hypercube", " ", 
     RowBox[{"sampler", ":", " ", 
      RowBox[{
       RowBox[{"m", " ", "points", " ", "in", " ", "the", " ", "d"}], "-", 
       RowBox[{"dimensional", " ", "unit", " ", "cube"}]}]}]}]}], " ", "*)"}],
   "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"latinHypercube", "[", 
      RowBox[{"m_Integer", ",", " ", "d_Integer"}], "]"}], " ", ":=", "\n", 
     "  ", 
     RowBox[{"Transpose", "@", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"RandomSample", "[", 
            RowBox[{"Range", "[", "m", "]"}], "]"}], " ", "-", " ", "1", " ", 
           "+", " ", 
           RowBox[{"RandomReal", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "m"}], "]"}]}], 
          ")"}], "/", "m"}], ",", " ", 
        RowBox[{"{", "d", "}"}]}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Integrate", " ", "one", " ", "sampled", " ", "system"}], ";", 
     " ", 
     RowBox[{
      RowBox[{"return", " ", "gene"}], " ", "->", " ", 
      "InterpolatingFunction"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"integrateSystem", "[", 
      RowBox[{
      "kap_Association", ",", " ", "gam_Association", ",", " ", 
       "th_Association", ",", " ", "n_", ",", " ", 
       RowBox[{"tmax_", " ", ":", " ", "100"}]}], "]"}], " ", ":=", "\n", 
     "  ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"eqs", ",", " ", "sol"}], "}"}], ",", "\n", "    ", 
       RowBox[{
        RowBox[{"eqs", " ", "=", " ", 
         RowBox[{"BooleanToOdeSystem", "[", 
          RowBox[{
          "FBmin", ",", " ", "t", ",", " ", "kap", ",", " ", "gam", ",", " ", 
           "th", ",", " ", "n", ",", " ", "var0", ",", " ", 
           RowBox[{"{", 
            RowBox[{"logisticm", ",", " ", "logisticp"}], "}"}]}], "]"}]}], ";",
         "\n", "    ", 
        RowBox[{"sol", " ", "=", " ", 
         RowBox[{"Quiet", "@", 
          RowBox[{"Check", "[", "\n", "        ", 
           RowBox[{
            RowBox[{"NDSolve", "[", 
             RowBox[{"eqs", ",", " ", "genes", ",", " ", 
              RowBox[{"{", 
               RowBox[{"t", ",", " ", "0", ",", " ", "tmax"}], "}"}], ",", 
              "\n", "          ", 
              RowBox[{
              "Method", " ", "->", " ", "\"\<StiffnessSwitching\>\""}], ",", 
              " ", 
              RowBox[{"MaxSteps", " ", "->", " ", 
               RowBox[{"10", "^", "6"}]}], ",", "\n", "          ", 
              RowBox[{"PrecisionGoal", " ", "->", " ", "6"}], ",", " ", 
              RowBox[{"AccuracyGoal", " ", "->", " ", "6"}]}], "]"}], ",", 
            " ", "$Failed"}], "]"}]}]}], ";", "\n", "    ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"sol", " ", "===", " ", "$Failed"}], " ", "||", " ", 
           RowBox[{
            RowBox[{"Head", "[", "sol", "]"}], " ", "=!=", " ", "List"}], " ",
            "||", " ", 
           RowBox[{"sol", " ", "===", " ", 
            RowBox[{"{", "}"}]}]}], ",", " ", "$Failed", ",", "\n", "       ", 
          RowBox[{"AssociationThread", "[", 
           RowBox[{"genes", " ", "->", " ", 
            RowBox[{"(", 
             RowBox[{"genes", " ", "/.", " ", 
              RowBox[{"First", "[", "sol", "]"}]}], ")"}]}], "]"}]}], 
         "]"}]}]}], "\n", "  ", "]"}]}], ";"}]}]}]], "Input",
 CellLabel->
  "In[134]:=",ExpressionUUID->"60bf2162-116a-44ce-abe9-b81964d6497b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Late-window amplitude, period, and limit-cycle classifier", "Section",ExpressionUUID->"8d5a7b4f-da21-41f5-a3ca-cd24e7b6d995"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Late", "-", 
    RowBox[{"window", " ", "amplitude", " ", "and", " ", "period", " ", 
     RowBox[{"(", 
      RowBox[{"mid", "-", 
       RowBox[{"level", " ", "up"}], "-", "crossings"}], ")"}]}]}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"lateAmpPeriod", "[", 
      RowBox[{"f_", ",", " ", 
       RowBox[{"win_", " ", ":", " ", "60"}], ",", " ", 
       RowBox[{"tmax_", " ", ":", " ", "100"}], ",", " ", 
       RowBox[{"npts_", " ", ":", " ", "801"}]}], "]"}], " ", ":=", "\n", 
     "  ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "ts", ",", " ", "ys", ",", " ", "ymax", ",", " ", "ymin", ",", " ", 
         "amp", ",", " ", "mid", ",", " ", "cross", ",", " ", "per"}], "}"}], 
       ",", "\n", "    ", 
       RowBox[{
        RowBox[{"ts", "   ", "=", " ", 
         RowBox[{"Subdivide", "[", 
          RowBox[{"win", ",", " ", "tmax", ",", " ", 
