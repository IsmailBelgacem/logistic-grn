Notebook[{

Cell[CellGroupData[{
Cell["Boolean-to-Logistic ODE Translation", "Title",ExpressionUUID->"6e33927f-0274-439a-a41c-fe2d0547e232"],

Cell["Ismail Belgacem 2026", "Author",
 CellChangeTimes->{{3.99191548083414*^9, 
  3.991915482092091*^9}},ExpressionUUID->"b9678ced-ba0c-4154-8119-\
dd618b2f1c1a"],

Cell["Paris", "Affiliation",ExpressionUUID->"2afc8bac-ce2f-4c1e-84d4-b53b78c7505a"],


Cell[BoxData[{
 RowBox[{
  RowBox[{"BeginPackage", "[", "\"\<BooleanToLogisticODE`\>\"", "]"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"Unprotect", "[", "\"\<BooleanToLogisticODE`*\>\"", "]"}], 
  ";"}]}], "Input",
 InitializationCell->True,
 CellLabel->
  "In[342]:=",ExpressionUUID->"98bba5a1-ec5f-4a9a-b79f-70bfe75e025c"],

Cell["Public API: usage messages.", "Text",ExpressionUUID->"4d2d663a-e3e2-4fa3-ba77-53460dbf5fd8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"BooleanToOdeSystem", "::", "usage"}], " ", "=", 
    " ", "\"\<BooleanToOdeSystem[F,v,\[Kappa],\[Gamma],\[Theta],n,var0,fstep] \
converts a Boolean network into an ODE system. The structures are \
associations whose keys are the network variables. F: Boolean network (list \
of rules variable \[Rule] Boolean formula). v: system variable (default t). \
\[Kappa]: expression rate. \[Gamma]: decay rate. \[Theta]: expression \
threshold. n: Hill coefficient (steepness). var0: initial condition. fstep: \
pair {inhibition, activation} step functions.\>\""}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"logisticp", "::", "usage"}], " ", "=", 
    " ", "\"\<logisticp[x,thr,n] is the increasing (activation) logistic \
kernel 1/(1+Exp[-(n/thr)(x-thr)]). The steepness matches a Hill function of \
cooperativity n at the threshold via \[Lambda]=n/thr.\>\""}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"logisticm", "::", "usage"}], " ", "=", 
    " ", "\"\<logisticm[x,thr,n] is the decreasing (repression) logistic \
kernel 1/(1+Exp[(n/thr)(x-thr)]). The steepness matches a Hill function of \
cooperativity n at the threshold via \[Lambda]=n/thr.\>\""}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"b2o", "::", "nnarg"}], " ", "=", 
   " ", "\"\<Syntax error: formula not recognized, aborted: `1`  \>\""}], 
  ";"}]}], "Input",
 InitializationCell->True,
 CellLabel->
  "In[344]:=",ExpressionUUID->"ff1c97d2-c335-401e-9f7b-9f3ca340b227"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Begin", "[", "\"\<`Private`\>\"", "]"}], ";"}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[348]:=",ExpressionUUID->"bb466ddd-2308-476f-8598-20c9392f03c3"],

Cell["Logistic kernels (\[Lambda]_i = n / thr).", "Text",ExpressionUUID->"a1b94644-7a35-4caf-9331-ddcb2bac42a2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"logisticp", "[", 
    RowBox[{
     RowBox[{"x_", "?", "NumericQ"}], ",", " ", 
     RowBox[{"thr_", "?", "NumericQ"}], ",", " ", 
     RowBox[{"n_", "?", "NumericQ"}]}], "]"}], " ", ":=", " ", 
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{"1", " ", "+", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{"n", "/", "thr"}], ")"}]}], " ", 
        RowBox[{"(", 
         RowBox[{"x", " ", "-", " ", "thr"}], ")"}]}], "]"}]}], ")"}]}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"logisticm", "[", 
    RowBox[{
     RowBox[{"x_", "?", "NumericQ"}], ",", " ", 
     RowBox[{"thr_", "?", "NumericQ"}], ",", " ", 
     RowBox[{"n_", "?", "NumericQ"}]}], "]"}], " ", ":=", " ", 
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{"1", " ", "+", " ", 
      RowBox[{"Exp", "[", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "/", "thr"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"x", " ", "-", " ", "thr"}], ")"}]}], "]"}]}], ")"}]}]}], 
  ";"}]}], "Input",
 InitializationCell->True,
 CellLabel->
  "In[349]:=",ExpressionUUID->"24291ef9-1a95-4a7b-8ef0-fadd3df4ddcc"],

Cell["\<\
Boolean network -> product-of-logistics ODE system (PURE De Morgan map). Each \
Boolean rule is mapped, through the recursive De Morgan correspondence, to a \
product of increasing/decreasing logistic factors; every gene obeys x_i'[v] \
== \[Kappa]_i * \[CapitalPhi]_i(x) - \[Gamma]_i * x_i[v], x_i[0] == var0_i. \
The rules F are assumed to be in minimal disjunctive normal form: since the \
soft map is neither idempotent nor distributive, that canonical form is what \
makes \[CapitalPhi] a function of the Boolean FUNCTION rather than of how it \
is written. Reduce the rules with BooleanMinimize in the calling program \
BEFORE passing them here.\
\>", "Text",ExpressionUUID->"f76cc3c4-7e46-4a13-8bd9-b31cdc604cdb"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "BooleanToOdeSystem", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"BooleanToOdeSystem", "[", 
   RowBox[{
   "F_", ",", " ", "v_Symbol", ",", " ", "\[Kappa]_Association", ",", " ", 
    "\[Gamma]_Association", ",", "\n", "    ", "\[Theta]_Association", ",", 
    " ", "n_", ",", " ", "var0_Association", ",", " ", 
    RowBox[{"fstep", ":", 
     RowBox[{"{", 
      RowBox[{"_Symbol", ",", " ", "_Symbol"}], "}"}]}]}], "]"}], " ", ":=", 
  "\n", "  ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"B2O", ",", " ", 
      RowBox[{"fneg", " ", "=", " ", 
       RowBox[{"fstep", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ",", " ", 
      RowBox[{"fpos", " ", "=", " ", 
       RowBox[{"fstep", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], ",", "\n", "    ", 
    RowBox[{
     RowBox[{
      RowBox[{"B2O", "[", "network_List", "]"}], "   ", ":=", " ", 
      RowBox[{"Flatten", "[", 
       RowBox[{"B2O", " ", "/@", " ", "network"}], "]"}]}], ";", "\n", "    ", 
     RowBox[{
      RowBox[{"B2O", "[", 
       RowBox[{"x_Symbol", " ", "->", " ", "f_"}], "]"}], " ", ":=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"x", "'"}], "[", "v", "]"}], " ", "==", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"\[Kappa]", "[", "x", "]"}], "*", 
           RowBox[{"B2O", "[", "f", "]"}]}], " ", "-", " ", 
          RowBox[{
           RowBox[{"\[Gamma]", "[", "x", "]"}], "*", 
           RowBox[{"x", "[", "v", "]"}]}]}]}], ",", "\n", 
        "                            ", 
        RowBox[{
         RowBox[{"x", "[", "0", "]"}], " ", "==", " ", 
         RowBox[{"var0", "[", "x", "]"}]}]}], "}"}]}], ";", "\n", "    ", 
     RowBox[{
      RowBox[{"B2O", "[", "var_Symbol", "]"}], "     ", ":=", " ", 
      RowBox[{"fpos", "[", 
       RowBox[{
        RowBox[{"var", "[", "v", "]"}], ",", " ", 
        RowBox[{"\[Theta]", "[", "var", "]"}], ",", " ", "n"}], "]"}]}], ";", 
     "\n", "    ", 
     RowBox[{
      RowBox[{"B2O", "[", 
       RowBox[{"\[Not]", " ", "var_Symbol"}], "]"}], " ", ":=", " ", 
      RowBox[{"fneg", "[", 
       RowBox[{
        RowBox[{"var", "[", "v", "]"}], ",", " ", 
        RowBox[{"\[Theta]", "[", "var", "]"}], ",", " ", "n"}], "]"}]}], ";", 
     "\n", "    ", 
     RowBox[{
      RowBox[{"B2O", "[", 
       RowBox[{"\[Not]", " ", "f_"}], "]"}], "      ", ":=", " ", 
      RowBox[{"1", " ", "-", " ", 
       RowBox[{"B2O", "[", "f", "]"}]}]}], ";", "\n", "    ", 
     RowBox[{
      RowBox[{"B2O", "[", 
       RowBox[{"f1_", " ", "\[And]", " ", "f2_"}], "]"}], "  ", ":=", " ", 
      RowBox[{
       RowBox[{"B2O", "[", "f1", "]"}], " ", "*", " ", 
       RowBox[{"B2O", "[", "f2", "]"}]}]}], ";", "\n", "    ", 
     RowBox[{
      RowBox[{"B2O", "[", 
       RowBox[{"f1_", " ", "\[Or]", " ", "f2_"}], "]"}], "   ", ":=", " ", 
      RowBox[{"1", " ", "-", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"B2O", "[", 
          RowBox[{"\[Not]", " ", "f1"}], "]"}], " ", "*", " ", 
         RowBox[{"B2O", "[", 
          RowBox[{"\[Not]", " ", "f2"}], "]"}]}], ")"}]}]}], ";", "\n", 
     "    ", 
     RowBox[{
      RowBox[{"B2O", "[", "True", "]"}], "  ", ":=", " ", "1"}], ";", "\n", 
     "    ", 
     RowBox[{
      RowBox[{"B2O", "[", "False", "]"}], " ", ":=", " ", "0"}], ";", "\n", 
     "    ", 
     RowBox[{
      RowBox[{"B2O", "[", "x_", "]"}], "    ", ":=", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Message", "[", 
         RowBox[{
          RowBox[{"b2o", "::", "nnarg"}], ",", " ", "x"}], "]"}], ";", " ", 
        RowBox[{"Abort", "[", "]"}]}], ")"}]}], ";", "\n", "    ", 
     RowBox[{"B2O", "[", "F", "]"}]}]}], "\n", "  ", "]"}]}]}], "Input",
 InitializationCell->True,
 CellLabel->
  "In[351]:=",ExpressionUUID->"3468c5f9-5a60-48a4-a626-38fd02979e11"],

Cell[BoxData[
 RowBox[{
  RowBox[{"End", "[", "]"}], ";"}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[353]:=",ExpressionUUID->"99239091-a64f-438a-9f40-78fb3b4578ec"],


Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SetAttributes", "[", 
     RowBox[{"#", ",", " ", 
      RowBox[{"{", "Protected", "}"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
   RowBox[{"{", 
    RowBox[{
    "BooleanToOdeSystem", ",", " ", "logisticp", ",", " ", "logisticm"}], 
    "}"}]}], ";"}], "\n", 
 RowBox[{"EndPackage", "[", "]"}]}], "Input",
 InitializationCell->True,
 CellLabel->
  "In[354]:=",ExpressionUUID->"e324dbae-b812-4cb6-9dde-81b4121e043d"]
}, Open  ]]
},
